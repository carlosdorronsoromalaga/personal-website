---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Carlos Dorronsoro Málaga · AI Consultant & Builder. Helping organisations adopt AI that actually works." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
const navActive = (href: string) =>
  (href === '/' ? path === '/' : path.startsWith(href))
    ? 'text-white'
    : 'hover:text-white';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} · Carlos Dorronsoro Málaga</title>
    <meta property="og:title" content={`${title} · Carlos Dorronsoro Málaga`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} · Carlos Dorronsoro Málaga`} />
    <meta name="twitter:description" content={description} />
    <meta name="author" content="Carlos Dorronsoro Málaga" />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Carlos Dorronsoro Málaga",
      "url": "https://carlosdorronsoromalaga.com",
      "image": "https://carlosdorronsoromalaga.com/images/headshot.jpg",
      "jobTitle": "Operations & Transformation Consultant, AI Specialist",
      "worksFor": { "@type": "Organization", "name": "PwC" },
      "description": "Industrial engineer turned AI specialist. Designs and leads AI adoption programmes, implements AI agent systems, and bridges the gap between emerging AI capabilities and real business operations.",
      "email": "carlos.dorronsoro.malaga@gmail.com",
      "nationality": "Spanish",
      "sameAs": [
        "https://www.linkedin.com/in/carlos-dorronsoro-malaga/",
        "https://github.com/carlosdorronsoromalaga"
      ],
      "knowsAbout": [
        "Artificial Intelligence", "AI Adoption", "AI Agent Design",
        "Digital Transformation", "Operations Management",
        "Financial Services", "Prompt Engineering", "Azure OpenAI"
      ],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Universidad Pontificia Comillas ICAI",
        "address": { "@type": "PostalAddress", "addressLocality": "Madrid", "addressCountry": "ES" }
      }
    })} />
  </head>

  <body class="min-h-screen bg-white text-slate-900">

    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-slate-950/90 backdrop-blur-md border-b border-white/5">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="font-bold text-white text-[0.95rem] tracking-tight hover:text-indigo-300 transition-colors" style="font-family:'Space Grotesk',sans-serif">
          Carlos <span class="text-indigo-400">Dorronsoro Málaga</span>
        </a>
        <ul class="hidden md:flex items-center gap-7 text-sm text-slate-400">
          <li><a href="/about" class={`${navActive('/about')} transition-colors`}>About</a></li>
          <li><a href="/projects" class={`${navActive('/projects')} transition-colors`}>Projects</a></li>
          <li><a href="/blog" class={`${navActive('/blog')} transition-colors`}>Blog</a></li>
          <li>
            <a href="/contact" class="rounded-lg bg-indigo-600 px-4 py-2 text-white font-medium hover:bg-indigo-500 transition-colors">
              Contact
            </a>
          </li>
        </ul>
        <!-- Mobile menu button -->
        <button id="menu-toggle" class="md:hidden text-slate-400 hover:text-white p-2" aria-label="Menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-slate-950 border-t border-white/5 px-6 py-4">
        <ul class="flex flex-col gap-4 text-sm text-slate-400">
          <li><a href="/about" class="hover:text-white transition-colors block py-1">About</a></li>
          <li><a href="/projects" class="hover:text-white transition-colors block py-1">Projects</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors block py-1">Blog</a></li>
          <li><a href="/contact" class="text-indigo-400 font-medium block py-1">Contact →</a></li>
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-slate-950 text-slate-500 border-t border-white/5">
      <div class="mx-auto max-w-6xl px-6 pt-10 pb-8 flex flex-col items-center gap-6 text-sm">
        <p class="text-slate-400 text-sm font-medium tracking-wide text-center italic">
          "AI is the core, not the feature."
        </p>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/in/carlos-dorronsoro-malaga/" target="_blank" rel="noopener"
             class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/15 text-slate-300 hover:bg-indigo-600 hover:border-indigo-500 hover:text-white transition-all"
             aria-label="LinkedIn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/carlosdorronsoromalaga" target="_blank" rel="noopener"
             class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/15 text-slate-300 hover:bg-slate-700 hover:border-slate-500 hover:text-white transition-all"
             aria-label="GitHub">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="mailto:carlos.dorronsoro.malaga@gmail.com"
             class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/15 text-slate-300 hover:bg-indigo-600 hover:border-indigo-500 hover:text-white transition-all"
             aria-label="Email">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>
        <span class="text-slate-600 text-xs">© 2026 Carlos Dorronsoro Málaga</span>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Scroll-aware header
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header?.classList.add('shadow-lg');
        } else {
          header?.classList.remove('shadow-lg');
        }
      });

      // Animate on scroll
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('aos-visible'); }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.aos').forEach(el => observer.observe(el));
    </script>

    <style is:global>
      .aos { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
      .aos-visible { opacity: 1; transform: translateY(0); }
    </style>
  </body>
</html>
