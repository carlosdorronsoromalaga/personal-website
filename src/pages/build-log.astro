---
import Layout from '../layouts/Layout.astro';

const entries = [
  {
    date: "2026-05-31",
    title: "Personal website v2 — rebuilding with Astro",
    project: "This site",
    excerpt: "Scrapped the content-only repo and rebuilt with Astro + Tailwind. Goal: a real web presence for the Dutch job search, not just a digital CV. Starting from the content structure that already existed.",
  },
  {
    date: "2026-05",
    title: "JobAgent — 8,000 jobs, 300+ tailored applications",
    project: "JobAgent",
    excerpt: "The pipeline hit meaningful scale. Integrated Workday ATS, Greenhouse, and Recruitee alongside LinkedIn. Added auto-chaining between discovery, scoring, and tailoring runs. The manual bottleneck is now applying, not generating.",
  },
  {
    date: "2026-04",
    title: "EVA — first user tests",
    project: "EVA",
    excerpt: "Ran the first informal validation sessions with elderly users. Biggest finding: the button matters as much as the AI. Physical affordances are part of the UX, not just the voice interaction. Back to the drawing board on the hardware concept.",
  },
  {
    date: "2026-03",
    title: "EduPath — validation and expansion",
    project: "EduPath",
    excerpt: "EduPath moved from concept to validated product. First cohort of real learners completed. Adaptation algorithm working better than expected on STEM content, weaker on creative skills — refining the curriculum generation prompts.",
  },
  {
    date: "2026-01",
    title: "WorldCup App — shipped",
    project: "WorldCup App",
    excerpt: "Completed the AI-first development experiment. Full product from zero to deployed in under 3 weeks using AI tools throughout. Key lesson: AI doesn't replace judgment, it amplifies it — for better and worse.",
  },
];
---

<Layout title="Build Log" description="Carlos Dorronsoro's build log — documented development journey across EVA, EduPath, JobAgent, and more.">
  <div class="mx-auto max-w-3xl px-6 pt-32 pb-24">

    <p class="text-sm font-semibold uppercase tracking-widest text-blue-400 mb-4">Build Log</p>
    <h1 class="text-4xl font-bold text-white mb-4">How I think. What I build.</h1>
    <p class="text-slate-400 text-lg mb-16 max-w-xl">
      Not polished posts — working notes on decisions made, lessons learned, and things that didn't work the way I expected.
    </p>

    <div class="space-y-8">
      {entries.map(entry => (
        <article class="border-l-2 border-slate-800 pl-8 pb-2 hover:border-blue-600 transition-colors group">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <time class="text-xs text-slate-500">{entry.date}</time>
            <span class="text-xs text-blue-400 bg-blue-950/40 rounded px-2 py-0.5">{entry.project}</span>
          </div>
          <h2 class="text-white font-semibold text-lg mb-2 group-hover:text-blue-400 transition-colors">{entry.title}</h2>
          <p class="text-slate-400 text-sm leading-relaxed">{entry.excerpt}</p>
        </article>
      ))}
    </div>

  </div>
</Layout>
