---
import Layout from '../layouts/Layout.astro';

// Add new lab items here: just add an object to this array
// Add your lab items here when ready:
// { title: "Name", description: "What it is.", url: "/lab/folder/index.html", tags: ["HTML"], date: "2026", emoji: "🔬" }
const items: { title: string; description: string; url: string; tags: string[]; date: string; emoji: string }[] = [];
---

<Layout title="Lab" description="Carlos Dorronsoro Málaga's lab: experiments, tools and projects in progress.">

  <section class="bg-slate-950 pt-32 pb-16">
    <div class="mx-auto max-w-6xl px-6">
      <span class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-4 block">Lab</span>
      <h1 class="text-4xl font-extrabold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">Lab</h1>
      <p class="text-slate-400 text-lg max-w-2xl">
        Experiments, tools and things I find interesting. No polish required.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto max-w-6xl px-6">
      {items.length === 0 ? (
        <p class="text-slate-400 text-center py-20">Coming soon.</p>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {items.map((item, i) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener"
              class="group bg-slate-50 rounded-2xl border border-slate-200 p-6 hover:border-indigo-300 hover:shadow-md transition-all aos"
              style={`transition-delay:${i * 60}ms`}
            >
              <div class="text-3xl mb-4">{item.emoji}</div>
              <h2 class="font-bold text-slate-900 text-lg mb-2 group-hover:text-indigo-600 transition-colors" style="font-family:'Space Grotesk',sans-serif">
                {item.title}
              </h2>
              <p class="text-slate-500 text-sm leading-relaxed mb-4">{item.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex gap-2 flex-wrap">
                  {item.tags.map(t => (
                    <span class="text-xs text-indigo-500 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>
                  ))}
                </div>
                <span class="text-xs text-slate-400">{item.date}</span>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-16 p-6 bg-slate-50 rounded-2xl border border-dashed border-slate-300 text-center aos">
        <p class="text-slate-400 text-sm">
          More coming. Drop your HTML in <code class="bg-white border border-slate-200 rounded px-1.5 py-0.5 text-xs font-mono">public/lab/name/</code>
          and add an entry in <code class="bg-white border border-slate-200 rounded px-1.5 py-0.5 text-xs font-mono">src/pages/lab.astro</code>
        </p>
      </div>
    </div>
  </section>

</Layout>
