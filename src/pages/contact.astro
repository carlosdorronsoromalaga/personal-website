---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Carlos Dorronsoro Málaga.">

  <section class="bg-slate-950 pt-32 pb-16">
    <div class="mx-auto max-w-6xl px-6">
      <span class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-4 block">Contact</span>
      <h1 class="text-4xl font-extrabold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">Let's talk.</h1>
      <p class="text-slate-400 text-lg max-w-xl">
        Open to conversations about roles, collaborations, projects, or anything interesting. If something here resonated, reach out.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6 grid lg:grid-cols-2 gap-16">

      <div class="space-y-4 aos">
        {[
          {
            label: "Email",
            value: "carlos.dorronsoro.malaga@gmail.com",
            href: "mailto:carlos.dorronsoro.malaga@gmail.com",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
          },
          {
            label: "LinkedIn",
            value: "linkedin.com/in/carlos-dorronsoro-malaga",
            href: "https://www.linkedin.com/in/carlos-dorronsoro-malaga/",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
          },
          {
            label: "GitHub",
            value: "github.com/carlosdorronsoromalaga",
            href: "https://github.com/carlosdorronsoromalaga",
            icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
          },
        ].map(c => (
          <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noopener"
             class="flex items-center gap-4 bg-slate-50 rounded-2xl border border-slate-200 p-5 hover:border-indigo-300 hover:shadow-md transition-all group">
            <div class="w-11 h-11 bg-indigo-600/10 text-indigo-600 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-indigo-600 group-hover:text-white transition-all"
                 set:html={c.icon}></div>
            <div>
              <div class="text-xs text-slate-400 mb-0.5">{c.label}</div>
              <div class="text-slate-900 font-medium text-sm group-hover:text-indigo-600 transition-colors">{c.value}</div>
            </div>
          </a>
        ))}
      </div>

      <div class="aos">
        <div class="bg-slate-950 rounded-2xl p-8 text-white">
          <div class="flex items-center gap-2 mb-6">
            <span class="w-2.5 h-2.5 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-sm text-slate-400">Open to conversations</span>
          </div>
          <p class="text-slate-300 leading-relaxed mb-4">
            The priority is always a great role — AI strategy, adoption, or product where AI is the core, not a feature.
          </p>
          <p class="text-slate-300 leading-relaxed mb-6">
            But I'm also open to collaborations, advisory, joint projects, or just a good conversation about what's happening in AI.
          </p>
          <p class="text-slate-500 text-sm">
            LinkedIn is the fastest way to reach me. I respond within 24 hours.
          </p>
        </div>
      </div>

    </div>
  </section>

</Layout>
