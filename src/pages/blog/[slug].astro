---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.excerpt}>

  <div class="bg-slate-950 pt-32 pb-16">
    <div class="mx-auto max-w-2xl px-6">
      <a href="/blog" class="text-sm text-slate-500 hover:text-indigo-400 transition-colors mb-8 inline-flex items-center gap-1">
        ← Blog
      </a>
      <time class="text-xs text-slate-500 uppercase tracking-wider mb-4 block">
        {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
        {post.data.title}
      </h1>
      <div class="flex gap-2 flex-wrap">
        {post.data.tags.map(t => (
          <span class="text-xs text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-2.5 py-0.5">{t}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="bg-white py-16">
    <div class="mx-auto max-w-2xl px-6 prose-blog">
      <Content />
    </div>
  </div>

</Layout>
