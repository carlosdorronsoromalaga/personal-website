---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Home">

  <!-- HERO -->
  <section class="relative min-h-screen bg-slate-950 flex items-center overflow-hidden pt-20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-indigo-600/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-indigo-900/10 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 py-20 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="inline-flex items-center gap-2 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-4 py-2 mb-8">
          <span class="w-2 h-2 bg-indigo-400 rounded-full animate-pulse"></span>
          <span class="text-indigo-300 text-xs font-semibold tracking-widest uppercase">Open to opportunities · Netherlands</span>
        </div>

        <h1 class="text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
          Carlos<br/><span class="text-indigo-400">Dorronsoro</span><br/>Málaga
        </h1>

        <p class="text-slate-300 text-xl font-light mb-3">AI Consultant · PwC</p>
        <p class="text-slate-400 text-lg leading-relaxed max-w-lg mb-10">
          I work at the intersection of AI, strategy, and people.
          By day I lead enterprise transformation — by night I build AI products from scratch.
          Always curious. Never done.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/about" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
            See my profile
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 border border-white/20 text-slate-300 px-6 py-3 rounded-xl font-semibold text-sm hover:border-indigo-400 hover:text-indigo-300 transition-all">
            Get in touch
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="hidden lg:flex justify-center items-center">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-indigo-600/20 to-transparent rounded-3xl blur-2xl"></div>
          <img
            src="/images/headshot.jpg"
            alt="Carlos Dorronsoro Málaga"
            class="relative w-80 h-80 object-cover object-top rounded-3xl border border-white/10 shadow-2xl"
            onerror="this.parentElement.innerHTML='<div class=\'relative w-80 h-80 rounded-3xl bg-slate-800 border border-white/10 flex items-center justify-center\'><span style=\'font-family:Space Grotesk;font-size:5rem;font-weight:800;color:#4f46e5\'>CD</span></div>'"
          />
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-600 text-xs tracking-widest uppercase">
      <span>Scroll</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- WHO I AM — three pillars -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl mb-16 aos">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">What I do</span>
        <h2 class="text-4xl font-bold text-slate-900 leading-tight" style="font-family:'Space Grotesk',sans-serif">
          Two years turning complexity into clarity — in boardrooms and codebases alike.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: "◈",
            title: "Enterprise AI Consultant",
            body: "At PwC I lead AI adoption programmes for large financial services clients — identifying where AI creates real value, designing the governance, and making it stick across organisations. Strategy through to execution.",
            cta: { label: "My experience", href: "/about#experience" },
          },
          {
            icon: "◉",
            title: "AI Product Builder",
            body: "I don't just advise on AI — I build with it. EVA, EduPath, and others: real products for real users. I use every available AI tool because I believe the best consultants also build.",
            cta: { label: "My projects", href: "/projects" },
          },
          {
            icon: "◎",
            title: "Curious by nature",
            body: "30+ countries. 7 years as a basketball referee. Chess competitor. I bring the same pattern-recognition and composure under pressure to every project I take on.",
            cta: { label: "Beyond work", href: "/about#beyond" },
          },
        ].map((p, i) => (
          <div class="group border-t-2 border-slate-200 hover:border-indigo-500 pt-6 transition-all aos" style={`transition-delay:${i * 100}ms`}>
            <div class="text-2xl text-indigo-500 mb-5">{p.icon}</div>
            <h3 class="text-lg font-bold text-slate-900 mb-3" style="font-family:'Space Grotesk',sans-serif">{p.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-5">{p.body}</p>
            <a href={p.cta.href} class="text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors inline-flex items-center gap-1">
              {p.cta.label}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS — light gray -->
  <section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between mb-12 aos">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">Projects</span>
          <h2 class="text-3xl font-bold text-slate-900" style="font-family:'Space Grotesk',sans-serif">Things I've built.</h2>
        </div>
        <a href="/projects" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors hidden sm:flex items-center gap-1">
          All projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            slug: "eva", emoji: "🎙️", name: "EVA",
            tagline: "Voice-first AI companion for elderly users",
            tags: ["Voice AI", "Healthcare"],
            status: "In validation",
            statusClass: "text-amber-700 bg-amber-50 border border-amber-200",
          },
          {
            slug: "edupath", emoji: "📚", name: "EduPath",
            tagline: "AI-driven personalised learning platform",
            tags: ["EdTech", "LLM"],
            status: "Live",
            statusClass: "text-emerald-700 bg-emerald-50 border border-emerald-200",
          },
          {
            slug: "worldcup-app", emoji: "⚽", name: "WorldCup App",
            tagline: "A full football app built entirely with AI",
            tags: ["Full-stack", "Experiment"],
            status: "Shipped",
            statusClass: "text-indigo-700 bg-indigo-50 border border-indigo-200",
          },
        ].map((p, i) => (
          <a href={`/projects/${p.slug}`}
             class="group bg-white rounded-2xl border border-slate-200 p-6 hover:border-indigo-300 hover:shadow-lg transition-all aos"
             style={`transition-delay:${i * 80}ms`}>
            <div class="text-3xl mb-4">{p.emoji}</div>
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-bold text-slate-900 text-lg group-hover:text-indigo-600 transition-colors" style="font-family:'Space Grotesk',sans-serif">{p.name}</h3>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ml-2 ${p.statusClass}`}>{p.status}</span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed mb-4">{p.tagline}</p>
            <div class="flex gap-2">
              {p.tags.map(t => <span class="text-xs text-indigo-600 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between mb-12 aos">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">Blog</span>
          <h2 class="text-3xl font-bold text-slate-900" style="font-family:'Space Grotesk',sans-serif">What I think about.</h2>
        </div>
        <a href="/blog" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors hidden sm:flex items-center gap-1">
          All posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      {posts.length === 0 ? (
        <p class="text-slate-400 text-sm">No posts yet — coming soon.</p>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`}
               class="group bg-slate-50 rounded-2xl border border-slate-100 p-7 hover:border-indigo-200 hover:shadow-md transition-all aos"
               style={`transition-delay:${i * 80}ms`}>
              <time class="text-xs text-slate-400 uppercase tracking-wider mb-3 block">
                {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="font-bold text-slate-900 text-lg mb-2 group-hover:text-indigo-600 transition-colors leading-snug" style="font-family:'Space Grotesk',sans-serif">
                {post.data.title}
              </h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-4">{post.data.excerpt}</p>
              <div class="flex gap-2 flex-wrap">
                {post.data.tags.map(t => <span class="text-xs text-indigo-500 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA — dark -->
  <section class="bg-slate-950 py-24">
    <div class="mx-auto max-w-6xl px-6 grid md:grid-cols-2 gap-12 items-center">
      <div class="aos">
        <h2 class="text-3xl font-bold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">
          Looking for an AI Consultant in the Netherlands?
        </h2>
        <p class="text-slate-400 leading-relaxed">
          I'm relocating to Amsterdam in 2026 and actively exploring opportunities in AI consulting, adoption, and product. EU citizen — no visa required.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 aos">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-indigo-600 text-white px-8 py-4 rounded-xl font-semibold hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
          Get in touch
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a href="/about" class="inline-flex items-center justify-center gap-2 border border-white/20 text-slate-300 px-8 py-4 rounded-xl font-semibold hover:border-indigo-400 hover:text-indigo-300 transition-all">
          See full profile
        </a>
      </div>
    </div>
  </section>

</Layout>
