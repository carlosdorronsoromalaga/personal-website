---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Home">

  <!-- HERO -->
  <section class="relative min-h-screen bg-slate-950 flex items-center overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-indigo-600/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-indigo-900/8 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 pt-24 pb-16 grid lg:grid-cols-2 gap-16 items-center w-full">
      <div>
        <!-- Role badge -->
        <div class="inline-flex items-center gap-2.5 mb-6">
          <img src="/images/pwc-logo.png" alt="PwC"
               class="h-5 object-contain brightness-0 invert opacity-70"
               onerror="this.style.display='none'" />
          <span class="text-slate-400 text-sm font-medium">Management Consultant · AI Specialist</span>
        </div>

        <h1 class="text-5xl lg:text-6xl font-extrabold text-white leading-[1.05] tracking-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
          Carlos<br/><span class="text-indigo-400">Dorronsoro</span><br/>Málaga
        </h1>

        <p class="text-slate-300 text-lg leading-relaxed max-w-lg mb-10">
          I help large organisations adopt AI in a way that actually changes how they work.
          Two years at PwC leading enterprise transformation across Europe —
          and I've been building AI products on my own time ever since.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/about" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
            View my profile
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 border border-white/20 text-slate-300 px-6 py-3 rounded-xl font-semibold text-sm hover:border-indigo-400 hover:text-indigo-300 transition-all">
            Get in touch
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div class="hidden lg:flex justify-center items-center">
        <div class="relative">
          <div class="absolute -inset-6 bg-gradient-to-br from-indigo-600/15 to-transparent rounded-3xl blur-2xl"></div>
          <img
            src="/images/headshot.jpg"
            alt="Carlos Dorronsoro Málaga"
            class="relative w-80 h-80 object-cover object-top rounded-3xl border border-white/10 shadow-2xl"
            onerror="this.parentElement.innerHTML='<div class=\'relative w-80 h-80 rounded-3xl bg-slate-800 border border-white/10 flex items-center justify-center\'><span style=\'font-family:Space Grotesk;font-size:5rem;font-weight:800;color:#4f46e5\'>CD</span></div>'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-2xl mb-16 aos">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">What I bring</span>
        <h2 class="text-4xl font-bold text-slate-900 leading-tight" style="font-family:'Space Grotesk',sans-serif">
          A profile that combines strategy, technology, and the curiosity to keep building.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        {[
          {
            icon: "◈",
            title: "Enterprise AI Consultant",
            body: "At PwC I lead AI adoption programmes for large financial services clients — from identifying the right use cases to running the change management that makes it real. Strategy through to execution, across multiple European markets.",
            cta: { label: "My experience", href: "/about#experience" },
          },
          {
            icon: "◉",
            title: "AI Product Builder",
            body: "On my own time I build AI products from scratch. EVA, EduPath, WorldCup App — personal projects born from real problems I noticed and couldn't let go. I believe the best consultants don't just advise: they build.",
            cta: { label: "My projects", href: "/projects" },
          },
          {
            icon: "◎",
            title: "Curious by nature",
            body: "30+ countries visited. Seven years as a federated basketball referee. Chess competitor. I approach every new context with the same mindset: understand the system, then find where to make an impact.",
            cta: { label: "Beyond work", href: "/about#beyond" },
          },
        ].map((p, i) => (
          <div class="flex flex-col border-t-2 border-slate-200 hover:border-indigo-500 pt-8 transition-colors aos" style={`transition-delay:${i * 100}ms`}>
            <div class="text-2xl text-indigo-500 mb-5">{p.icon}</div>
            <h3 class="text-lg font-bold text-slate-900 mb-3" style="font-family:'Space Grotesk',sans-serif">{p.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-8">{p.body}</p>
            <div class="flex justify-center">
              <a href={p.cta.href}
                 class="inline-flex items-center gap-2 border border-indigo-200 text-indigo-600 bg-indigo-50 hover:bg-indigo-600 hover:text-white hover:border-indigo-600 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all">
                {p.cta.label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between mb-12 aos">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">Projects</span>
          <h2 class="text-3xl font-bold text-slate-900" style="font-family:'Space Grotesk',sans-serif">Things I've built.</h2>
        </div>
        <a href="/projects" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors hidden sm:flex items-center gap-1">
          All projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            slug: "eva", emoji: "🎙️", name: "EVA",
            tagline: "Voice-first AI companion for elderly users",
            tags: ["Voice AI", "Healthcare"],
            status: "In validation",
            statusClass: "text-amber-700 bg-amber-50 border border-amber-200",
          },
          {
            slug: "edupath", emoji: "📚", name: "EduPath",
            tagline: "AI-driven personalised learning platform",
            tags: ["EdTech", "LLM"],
            status: "Live",
            statusClass: "text-emerald-700 bg-emerald-50 border border-emerald-200",
          },
          {
            slug: "worldcup-app", emoji: "⚽", name: "WorldCup App",
            tagline: "A full football app built entirely with AI",
            tags: ["Full-stack", "Experiment"],
            status: "Shipped",
            statusClass: "text-indigo-700 bg-indigo-50 border border-indigo-200",
          },
        ].map((p, i) => (
          <a href={`/projects/${p.slug}`}
             class="group bg-white rounded-2xl border border-slate-200 p-6 hover:border-indigo-300 hover:shadow-lg transition-all aos"
             style={`transition-delay:${i * 80}ms`}>
            <div class="text-3xl mb-4">{p.emoji}</div>
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-bold text-slate-900 text-lg group-hover:text-indigo-600 transition-colors" style="font-family:'Space Grotesk',sans-serif">{p.name}</h3>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ml-2 ${p.statusClass}`}>{p.status}</span>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed mb-4">{p.tagline}</p>
            <div class="flex gap-2">
              {p.tags.map(t => <span class="text-xs text-indigo-600 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between mb-12 aos">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3 block">Blog</span>
          <h2 class="text-3xl font-bold text-slate-900" style="font-family:'Space Grotesk',sans-serif">What I think about.</h2>
        </div>
        <a href="/blog" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors hidden sm:flex items-center gap-1">
          All posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      {posts.length === 0 ? (
        <p class="text-slate-400 text-sm">No posts yet — coming soon.</p>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`}
               class="group bg-slate-50 rounded-2xl border border-slate-100 p-7 hover:border-indigo-200 hover:shadow-md transition-all aos"
               style={`transition-delay:${i * 80}ms`}>
              <time class="text-xs text-slate-400 uppercase tracking-wider mb-3 block">
                {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="font-bold text-slate-900 text-lg mb-2 group-hover:text-indigo-600 transition-colors leading-snug" style="font-family:'Space Grotesk',sans-serif">
                {post.data.title}
              </h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-4">{post.data.excerpt}</p>
              <div class="flex gap-2 flex-wrap">
                {post.data.tags.map(t => <span class="text-xs text-indigo-500 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA — dark, with logos -->
  <section class="bg-slate-950 py-24">
    <div class="mx-auto max-w-2xl px-6 text-center aos">
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">
        Looking for an AI Consultant in the Netherlands?
      </h2>
      <p class="text-slate-400 leading-relaxed mb-10">
        Relocating to Amsterdam in 2026 and actively exploring roles in AI consulting, adoption, and product. EU citizen — no visa required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <!-- Email CTA -->
        <a href="mailto:carlos.dorronsoro.malaga@gmail.com"
           class="inline-flex items-center justify-center gap-3 bg-indigo-600 text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email me
        </a>
        <!-- LinkedIn CTA -->
        <a href="https://www.linkedin.com/in/carlos-dorronsoro-malaga/" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-3 border border-white/20 text-slate-300 px-7 py-3.5 rounded-xl font-semibold hover:border-[#0a66c2] hover:text-[#60a5fa] transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

</Layout>
