---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Home">

  <!-- HERO — top-aligned, fills screen -->
  <section class="relative min-h-svh bg-slate-950 overflow-hidden" style="padding-top:96px; padding-bottom:80px;">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 right-0 w-[700px] h-[700px] bg-indigo-600/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-900/8 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="flex flex-wrap gap-2 mb-7">
          {["AI Consultant", "Builder", "Leader", "AI-Native"].map(k => (
            <span class="text-xs font-semibold text-indigo-300 bg-indigo-500/10 border border-indigo-500/20 rounded-full px-3 py-1.5 tracking-wide">{k}</span>
          ))}
        </div>

        <h1 class="text-5xl lg:text-6xl font-extrabold text-white leading-[1.05] tracking-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
          Carlos<br/><span class="text-indigo-400">Dorronsoro</span><br/>Málaga
        </h1>

        <p class="text-slate-300 text-lg leading-relaxed max-w-lg mb-10">
          I help large organisations adopt AI in ways that actually change how they work.
          Two years at PwC leading enterprise transformation across Europe,
          and building AI products from scratch on my own time ever since.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/about" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
            View my profile
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 border border-white/20 text-slate-300 px-6 py-3 rounded-xl font-semibold text-sm hover:border-indigo-400 hover:text-indigo-300 transition-all">
            Get in touch
          </a>
        </div>
      </div>

      <div class="hidden lg:flex justify-center items-center">
        <div class="relative">
          <div class="absolute -inset-6 bg-gradient-to-br from-indigo-600/15 to-transparent rounded-3xl blur-2xl"></div>
          <img
            src="/images/headshot.jpg"
            alt="Carlos Dorronsoro Málaga"
            class="relative w-80 h-80 object-cover object-top rounded-3xl border border-white/10 shadow-2xl"
            onerror="this.parentElement.innerHTML='<div class=\'relative w-80 h-80 rounded-3xl bg-slate-800 border border-white/10 flex items-center justify-center\'><span style=\'font-family:Space Grotesk;font-size:4rem;font-weight:800;color:#4f46e5\'>CD</span></div>'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT I BRING -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-4 block">What I bring</span>
        <h2 class="text-4xl font-bold text-slate-900 leading-tight" style="font-family:'Space Grotesk',sans-serif;">
          The bridge between business acumen,<br class="hidden lg:block"/> technology, and people.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Card 1: Enterprise AI Consultant -->
        <div class="flex flex-col rounded-2xl border border-indigo-100 overflow-hidden hover:border-indigo-300 hover:shadow-lg transition-all group">
          <div class="h-44 overflow-hidden bg-slate-100">
            <img src="/images/about-photo.jpg" alt=""
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 onerror="this.parentElement.style.background='linear-gradient(135deg,#e0e7ff,#c7d2fe)'" />
          </div>
          <div class="flex flex-col flex-1 p-7">
            <h3 class="text-lg font-bold text-slate-900 mb-3" style="font-family:'Space Grotesk',sans-serif">Enterprise AI Consultant</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-7">At PwC I lead AI adoption programmes for large financial services clients — from identifying the right use cases to running the change management that makes it real. Strategy through to execution, across multiple European markets.</p>
            <a href="/about#experience"
               class="inline-flex items-center justify-center gap-2 bg-indigo-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-indigo-500 transition-all hover:-translate-y-0.5">
              My experience
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Card 2: AI Product Builder -->
        <div class="flex flex-col rounded-2xl border border-violet-100 overflow-hidden hover:border-violet-300 hover:shadow-lg transition-all group">
          <div class="h-44 overflow-hidden bg-gradient-to-br from-violet-50 to-indigo-100 flex items-center justify-center">
            <div class="text-center px-6">
              <div class="flex justify-center gap-3 mb-3">
                <span class="text-xs font-bold text-violet-500 bg-white border border-violet-200 rounded-full px-3 py-1">EVA</span>
                <span class="text-xs font-bold text-indigo-500 bg-white border border-indigo-200 rounded-full px-3 py-1">EduPath</span>
                <span class="text-xs font-bold text-slate-500 bg-white border border-slate-200 rounded-full px-3 py-1">WorldCup</span>
              </div>
              <p class="text-xs text-slate-400 italic">Personal projects. Real problems.</p>
            </div>
          </div>
          <div class="flex flex-col flex-1 p-7">
            <h3 class="text-lg font-bold text-slate-900 mb-3" style="font-family:'Space Grotesk',sans-serif">AI Product Builder</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-7">On my own time I build AI products from scratch. EVA, EduPath, WorldCup App — personal projects born from real problems I couldn't let go. I believe the best advisors on AI are those who have actually built with it.</p>
            <a href="/projects"
               class="inline-flex items-center justify-center gap-2 bg-violet-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-violet-500 transition-all hover:-translate-y-0.5">
              My projects
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Card 3: Curious by nature -->
        <div class="flex flex-col rounded-2xl border border-slate-200 overflow-hidden hover:border-slate-300 hover:shadow-lg transition-all group">
          <div class="h-44 overflow-hidden bg-slate-100">
            <img src="/images/basketball.jpg" alt="Basketball referee"
                 class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                 onerror="this.parentElement.style.background='linear-gradient(135deg,#f1f5f9,#e2e8f0)'" />
          </div>
          <div class="flex flex-col flex-1 p-7">
            <h3 class="text-lg font-bold text-slate-900 mb-3" style="font-family:'Space Grotesk',sans-serif">Curious by nature</h3>
            <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-7">30+ countries visited. Seven years as a federated basketball referee. Chess competitor. I approach every new context with the same mindset: understand the system, then find where to make an impact.</p>
            <a href="/about#beyond"
               class="inline-flex items-center justify-center gap-2 bg-slate-800 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-slate-700 transition-all hover:-translate-y-0.5">
              Beyond work
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS — same card style, no emojis -->
  <section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-4 block">Projects</span>
        <h2 class="text-4xl font-bold text-slate-900 leading-tight" style="font-family:'Space Grotesk',sans-serif;">
          Things I've built on my own time.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            slug: "eva",
            name: "EVA",
            tagline: "Voice-first AI companion for elderly users",
            body: "The problem isn't ability — it's that technology isn't designed for them. EVA strips everything back to a single button and a voice.",
            tags: ["Voice AI", "Healthcare", "Python"],
            status: "In validation",
            statusClass: "text-amber-700 bg-amber-50 border-amber-200",
            cardBorder: "border-amber-100 hover:border-amber-300",
            btnClass: "bg-amber-500 hover:bg-amber-400",
          },
          {
            slug: "edupath",
            name: "EduPath",
            tagline: "AI-driven personalised learning platform",
            body: "Learning should adapt to you, not the other way around. EduPath uses LLMs to generate curricula that evolve with the learner.",
            tags: ["EdTech", "LLM", "Product"],
            status: "Live",
            statusClass: "text-emerald-700 bg-emerald-50 border-emerald-200",
            cardBorder: "border-emerald-100 hover:border-emerald-300",
            btnClass: "bg-emerald-600 hover:bg-emerald-500",
          },
          {
            slug: "worldcup-app",
            name: "WorldCup App",
            tagline: "A full football prediction app, built entirely with AI",
            body: "An experiment in AI-first development: from spec to deployed product using AI tools throughout — design, code, testing, and launch.",
            tags: ["Full-stack", "React", "Experiment"],
            status: "Shipped",
            statusClass: "text-indigo-700 bg-indigo-50 border-indigo-200",
            cardBorder: "border-indigo-100 hover:border-indigo-300",
            btnClass: "bg-indigo-600 hover:bg-indigo-500",
          },
        ].map(p => (
          <div class={`group flex flex-col rounded-2xl border bg-white overflow-hidden hover:shadow-lg transition-all ${p.cardBorder}`}>
            <div class="p-7 flex flex-col flex-1">
              <div class="flex items-start justify-between mb-4">
                <h3 class="text-xl font-bold text-slate-900" style="font-family:'Space Grotesk',sans-serif">{p.name}</h3>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border shrink-0 ml-3 ${p.statusClass}`}>{p.status}</span>
              </div>
              <p class="text-sm font-medium text-slate-700 mb-2">{p.tagline}</p>
              <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-5">{p.body}</p>
              <div class="flex flex-wrap gap-1.5 mb-7">
                {p.tags.map(t => <span class="text-xs text-slate-500 bg-slate-100 rounded-full px-2.5 py-0.5">{t}</span>)}
              </div>
              <a href={`/projects/${p.slug}`}
                 class={`inline-flex items-center justify-center gap-2 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all hover:-translate-y-0.5 ${p.btnClass}`}>
                View project
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-14">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-4 block">Blog</span>
        <h2 class="text-4xl font-bold text-slate-900 leading-tight" style="font-family:'Space Grotesk',sans-serif;">
          Always thinking. Sometimes writing.
        </h2>
        <p class="text-slate-500 mt-3 text-lg max-w-2xl">
          No schedule, no format. Just things I find worth sharing — about AI, building, consulting, or whatever's on my mind.
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-slate-400 text-sm">No posts yet — coming soon.</p>
      ) : (
        <div class="grid sm:grid-cols-2 gap-6">
          {posts.map(post => (
            <a href={`/blog/${post.id}`}
               class="group bg-slate-50 rounded-2xl border border-slate-100 p-7 hover:border-indigo-200 hover:shadow-md transition-all">
              <time class="text-xs text-slate-400 uppercase tracking-wider mb-3 block">
                {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <h3 class="font-bold text-slate-900 text-xl mb-2 group-hover:text-indigo-600 transition-colors leading-snug" style="font-family:'Space Grotesk',sans-serif">
                {post.data.title}
              </h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-5">{post.data.excerpt}</p>
              <div class="flex items-center justify-between">
                <div class="flex gap-2 flex-wrap">
                  {post.data.tags.map(t => <span class="text-xs text-indigo-500 bg-indigo-50 rounded-full px-2.5 py-0.5">{t}</span>)}
                </div>
                <span class="text-sm font-semibold text-indigo-600 group-hover:text-indigo-800 transition-colors shrink-0 ml-4">Read →</span>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-8 text-center">
        <a href="/blog" class="inline-flex items-center gap-2 border border-slate-200 text-slate-600 px-6 py-3 rounded-xl font-semibold text-sm hover:border-indigo-300 hover:text-indigo-600 transition-all">
          All posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-950 py-24">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">
        Looking for an AI Consultant in the Netherlands?
      </h2>
      <p class="text-slate-400 leading-relaxed mb-10">
        Relocating to Amsterdam in 2026. Actively exploring roles in AI consulting, adoption, and product. EU citizen — no visa required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="mailto:carlos.dorronsoro.malaga@gmail.com"
           class="inline-flex items-center justify-center gap-3 bg-indigo-600 text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-indigo-500 transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-600/25">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email me
        </a>
        <a href="https://www.linkedin.com/in/carlos-dorronsoro-malaga/" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-3 border border-white/20 text-slate-300 px-7 py-3.5 rounded-xl font-semibold hover:border-[#0a66c2] hover:text-[#60a5fa] transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>

</Layout>
