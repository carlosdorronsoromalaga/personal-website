---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    slug: "eva",
    name: "EVA",
    tagline: "Voice-first AI companion for elderly users",
    description: "The problem isn't ability; it's that technology isn't designed for them. EVA is built around voice: press a button, speak. No apps, no screens, no complexity. Designed with and for people who deserve better tech.",
    tags: ["Voice AI", "Healthcare", "Python", "LLM"],
    status: "Building",
    statusColor: "amber",
    headerFrom: "#451a03",
    headerTo: "#7c2d12",
    previewImg: "/images/eva-mockup.png",
  },
  {
    slug: "edupath",
    name: "EduPath",
    tagline: "AI-driven personalised learning platform",
    description: "Learning that adapts to you. EduPath uses LLMs to generate personalised curricula, track progress, and surface the right content at the right moment. First use cases validated with real learners. Building the transversal solution.",
    tags: ["EdTech", "LLM", "Product", "React"],
    status: "Building",
    statusColor: "amber",
    headerFrom: "#022c22",
    headerTo: "#134e4a",
    previewUrl: "/demos/edupath-programa-enfermeria.html",
  },
  {
    slug: "worldcup-app",
    name: "WorldCup App",
    tagline: "A football prediction app built entirely with AI",
    description: "From spec to deployed product using AI tools throughout: design, code, testing, deployment. An experiment in what AI-first development actually looks like end to end. Built and shipped in under a week.",
    tags: ["Full-stack", "AI-built", "React", "Deployed"],
    status: "Live",
    statusColor: "emerald",
    headerFrom: "#1e1b4b",
    headerTo: "#312e81",
    previewUrl: "https://maalimundial2026.netlify.app",
  },
];

const statusClasses: Record<string, string> = {
  amber: "text-amber-700 bg-amber-50 border border-amber-200",
  emerald: "text-emerald-700 bg-emerald-50 border border-emerald-200",
};
---

<Layout title="Projects" description="AI projects built by Carlos Dorronsoro Málaga: EVA (voice AI for elderly users), EduPath (personalised learning with LLMs), WorldCup App (AI-first full-stack development).">

  <section class="bg-slate-950 pt-32 pb-16">
    <div class="mx-auto max-w-5xl px-6">
      <span class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-4 block">Projects</span>
      <h1 class="text-4xl font-extrabold text-white mb-4" style="font-family:'Space Grotesk',sans-serif">Things I've built.</h1>
      <p class="text-slate-400 text-lg max-w-2xl">
        Every project started with a genuine problem. Not portfolio exercises, but real attempts to build something useful.
      </p>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="space-y-10">
        {projects.map((p) => (
          <div class="group rounded-2xl border border-slate-200 overflow-hidden hover:border-slate-300 hover:shadow-xl transition-all duration-300 bg-white">

            <!-- Visual preview header -->
            <div class="h-64 relative overflow-hidden"
                 style={`background: linear-gradient(135deg, ${p.headerFrom}, ${p.headerTo})`}>
              {p.previewUrl ? (
                <iframe
                  src={p.previewUrl}
                  class="absolute top-0 left-0 border-0 pointer-events-none"
                  style="width: 1440px; height: 900px; transform: scale(0.5); transform-origin: top left;"
                  loading="lazy"
                  aria-hidden="true"
                  tabindex="-1"
                />
              ) : p.previewImg ? (
                <img
                  src={p.previewImg}
                  class="w-full h-full object-cover object-top"
                  alt={p.name}
                  onerror="this.style.display='none'"
                />
              ) : null}
            </div>

            <!-- Content -->
            <div class="p-7">
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h2 class="text-2xl font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors" style="font-family:'Space Grotesk',sans-serif">
                    {p.name}
                  </h2>
                  <p class="text-slate-500 text-sm mt-0.5">{p.tagline}</p>
                </div>
                <span class={`text-xs font-semibold px-3 py-1 rounded-full shrink-0 mt-1 ${statusClasses[p.statusColor]}`}>
                  {p.status}
                </span>
              </div>

              <p class="text-slate-600 leading-relaxed mb-5">{p.description}</p>

              <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex gap-2 flex-wrap">
                  {p.tags.map(t => (
                    <span class="text-xs text-slate-600 bg-slate-100 rounded-full px-2.5 py-0.5 font-medium">{t}</span>
                  ))}
                </div>
                <a href={`/projects/${p.slug}`}
                   class="text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors shrink-0 inline-flex items-center gap-1">
                  View project →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-200 text-center">
        <p class="text-slate-500 text-sm">
          More experiments in progress. The best ideas are still half-formed.
        </p>
      </div>
    </div>
  </section>

</Layout>
